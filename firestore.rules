rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /builds/{buildId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /publicBuilds/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /case/{docId}                 { allow read: if true; allow write: if false; }
    match /case-accessory/{docId}       { allow read: if true; allow write: if false; }
    match /case-fan/{docId}             { allow read: if true; allow write: if false; }
    match /cpu/{docId}                  { allow read: if true; allow write: if false; }
    match /cpu-cooler/{docId}           { allow read: if true; allow write: if false; }
    match /external-hard-drive/{docId}  { allow read: if true; allow write: if false; }
    match /fan-controller/{docId}       { allow read: if true; allow write: if false; }
    match /internal-hard-drive/{docId}  { allow read: if true; allow write: if false; }
    match /memory/{docId}               { allow read: if true; allow write: if false; }
    match /motherboard/{docId}          { allow read: if true; allow write: if false; }
    match /optical-drive/{docId}        { allow read: if true; allow write: if false; }
    match /os/{docId}                   { allow read: if true; allow write: if false; }
    match /power-supply/{docId}         { allow read: if true; allow write: if false; }
    match /sound-card/{docId}           { allow read: if true; allow write: if false; }
    match /thermal-paste/{docId}        { allow read: if true; allow write: if false; }
    match /ups/{docId}                  { allow read: if true; allow write: if false; }
    match /video-card/{docId}           { allow read: if true; allow write: if false; }
    match /wired-network-card/{docId}   { allow read: if true; allow write: if false; }
    match /wireless-network-card/{docId}{ allow read: if true; allow write: if false; }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
